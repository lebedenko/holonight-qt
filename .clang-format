---
Language: Cpp
BasedOnStyle: Google
Standard: Latest
ColumnLimit: 120
IndentWidth: 2
AccessModifierOffset: -1
IncludeBlocks: Regroup
IncludeCategories:
  - Regex: '^<Q.*>'
    Priority: 2
  - Regex: '^<.*>'
    Priority: 3
  - Regex: '".*"'
    Priority: 1
SortIncludes:
  Enabled: true
  IgnoreCase: false
  IgnoreExtension: true
